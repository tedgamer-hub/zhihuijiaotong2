# Local development keeps the API base empty so Vite can proxy /api requests.
VITE_API_BASE_URL=

# Production builds should include the Spring Boot context path: /IntelliDetect
# VITE_API_BASE_URL=https://your-backend-domain.example.com/IntelliDetect

# Optional for mvp_static_server.cjs and mvp_static_server.py.
# BACKEND_BASE_URL=http://localhost:8080/IntelliDetect
